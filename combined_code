#include <SoftwareSerial.h>

// Bench mapping:
// Temp -> Serial1  (TX1=18, RX1=19)
// DO   -> Serial2  (TX2=16, RX2=17)
// pH   -> Serial3  (TX3=14, RX3=15)
// EC   -> SoftwareSerial (RX=10, TX=11)
// Leak -> pin 53

SoftwareSerial ecSerial(10, 11); // Arduino RX, TX

const int leakPin = 53;
const int ledPin  = 13;

unsigned long lastRequest = 0;
const unsigned long interval = 3000;
const unsigned long responseDelay = 1200; // give sensors time to answer
bool waitingForResponses = false;

float phValue = 0.0;
float tempValue = 0.0;
float ecValue = 0.0;
float tdsValue = 0.0;
float salValue = 0.0;
float gravValue = 0.0;
float doValue = 0.0;

bool phValid = false;
bool tempValid = false;
bool ecValid = false;
bool doValid = false;

String phBuffer = "";
String tempBuffer = "";
String ecBuffer = "";
String doBuffer = "";

bool isNumericStart(const String &s) {
  if (s.length() == 0) return false;
  char c = s[0];
  return isDigit(c) || c == '-' || c == '.';
}

void clearPort(Stream &port) {
  while (port.available()) {
    port.read();
  }
}

void servicePort(Stream &port, String &buffer, void (*parser)(String)) {
  while (port.available()) {
    char c = port.read();
    if (c == '\r' || c == '\n') {
      if (buffer.length() > 0) {
        parser(buffer);
        buffer = "";
      }
    } else {
      buffer += c;
    }
  }
}

void parsePH(String msg) {
  msg.trim();
  Serial.print("[RAW pH] ");
  Serial.println(msg);

  if (isNumericStart(msg)) {
    phValue = msg.toFloat();
    phValid = true;
  } else {
    Serial.print("pH status: ");
    Serial.println(msg);
  }
}

void parseTemp(String msg) {
  msg.trim();
  Serial.print("[RAW Temp] ");
  Serial.println(msg);

  if (isNumericStart(msg)) {
    tempValue = msg.toFloat();
    tempValid = true;
  } else {
    Serial.print("Temp status: ");
    Serial.println(msg);
  }
}

void parseDO(String msg) {
  msg.trim();
  Serial.print("[RAW DO] ");
  Serial.println(msg);

  if (isNumericStart(msg)) {
    doValue = msg.toFloat();
    doValid = true;
  } else {
    Serial.print("DO status: ");
    Serial.println(msg);
  }
}

void parseEC(String msg) {
  msg.trim();
  Serial.print("[RAW EC] ");
  Serial.println(msg);

  if (!isNumericStart(msg)) {
    Serial.print("EC status: ");
    Serial.println(msg);
    return;
  }

  char buf[40];
  msg.toCharArray(buf, sizeof(buf));

  char *EC   = strtok(buf, ",");
  char *TDS  = strtok(NULL, ",");
  char *SAL  = strtok(NULL, ",");
  char *GRAV = strtok(NULL, ",");

  if (EC)   ecValue   = atof(EC);
  if (TDS)  tdsValue  = atof(TDS);
  if (SAL)  salValue  = atof(SAL);
  if (GRAV) gravValue = atof(GRAV);

  ecValid = true;
}

void requestAllSensors() {
  // clear old junk before new request
  clearPort(Serial1);
  clearPort(Serial2);
  clearPort(Serial3);
  clearPort(ecSerial);

  phBuffer = "";
  tempBuffer = "";
  ecBuffer = "";
  doBuffer = "";

  Serial.println("Sending R to all sensors...");

  Serial1.print("R\r");   // Temp
  Serial2.print("R\r");   // DO
  Serial3.print("R\r");   // pH
  ecSerial.print("R\r");  // EC

  lastRequest = millis();
  waitingForResponses = true;
}

void printReadings() {
  int leak = digitalRead(leakPin);
  digitalWrite(ledPin, leak);

  Serial.println("-------------------------- Bench Readings --------------------------");

  Serial.print("pH: ");
  if (phValid) Serial.println(phValue, 2);
  else Serial.println("NA");

  Serial.print("Temp (C): ");
  if (tempValid) Serial.println(tempValue, 2);
  else Serial.println("NA");

  Serial.print("DO: ");
  if (doValid) Serial.println(doValue, 2);
  else Serial.println("NA");

  Serial.print("EC: ");
  if (ecValid) Serial.println(ecValue, 2);
  else Serial.println("NA");

  Serial.print("TDS: ");
  if (ecValid) Serial.println(tdsValue, 2);
  else Serial.println("NA");

  Serial.print("SAL: ");
  if (ecValid) Serial.println(salValue, 2);
  else Serial.println("NA");

  Serial.print("GRAV: ");
  if (ecValid) Serial.println(gravValue, 3);
  else Serial.println("NA");

  Serial.print("Leak: ");
  if (leak) Serial.println("DETECTED");
  else Serial.println("Dry");

  Serial.println();
}

void setup() {
  pinMode(leakPin, INPUT);
  pinMode(ledPin, OUTPUT);

  Serial.begin(115200);
  Serial1.begin(9600);   // Temp
  Serial2.begin(9600);   // DO
  Serial3.begin(9600);   // pH
  ecSerial.begin(9600);  // EC

  Serial.println("Starting the becnh");
  delay(1500);

  requestAllSensors();
}

void loop() {
  servicePort(Serial3, phBuffer, parsePH);
  servicePort(Serial1, tempBuffer, parseTemp);
  servicePort(Serial2, doBuffer, parseDO);
  servicePort(ecSerial, ecBuffer, parseEC);

  if (waitingForResponses && millis() - lastRequest >= responseDelay) {
    printReadings();
    waitingForResponses = false;
  }

  if (!waitingForResponses && millis() - lastRequest >= interval) {
    requestAllSensors();
  }
}
